{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":timezone(Asia/Tokyo)"
    ],
    "labels": [
        "Renovate"
    ],
    "prHourlyLimit": 0,
    "prConcurrentLimit": 5,
    "dependencyDashboard": true,
    "minimumReleaseAge": "14 days",
    "packageRules": [
        {
            "matchUpdateTypes": [
                "patch"
            ],
            "automerge": true
        }
    ],
    "internalChecksFilter": "strict"
}
